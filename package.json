{
  "name": "eyeguard-ai",
  "version": "1.0.0",
  "description": "EyeGuard AI — персональный офтальмолог в Telegram",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "dev:bot": "tsx watch src/bot/bot.ts",
    "dev:webapp": "vite",
    "build": "tsc && vite build",
    "build:webapp": "vite build",
    "start": "node dist/api/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "framer-motion": "^12.38.0",
    "grammy": "^1.32.0",
    "lucide-react": "^1.14.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  }
}
